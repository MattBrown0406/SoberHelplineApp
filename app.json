{
  "expo": {
    "name": "Sober Helpline",
    "slug": "SoberHelplineApp",
    "version": "3.1",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "sober-helpline",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#142a47"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.soberhelplineapp",
      "buildNumber": "12",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Sober Helpline uses your microphone only during practice recording, live group sessions, and private video support sessions you choose to join.",
        "NSCameraUsageDescription": "Sober Helpline uses your camera only during live group sessions and private video support sessions you choose to join.",
        "NSPhotoLibraryUsageDescription": "Sober Helpline lets you attach screenshots to your private in-app support thread when you choose to share them.",
        "UISupportedInterfaceOrientations": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortrait"
        ],
        "UISupportedInterfaceOrientations~ipad": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight",
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight",
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight",
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#142a47"
      },
      "package": "com.soberhelplineapp",
      "versionCode": 3,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withPodfilePatch",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#142a47",
          "resizeMode": "contain"
        }
      ],
      "expo-asset",
      "expo-localization",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#142a47",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "2858ea55-7e40-4b09-8928-fe9155c1772d"
      }
    },
    "owner": "mattbrown0406s-organization",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2858ea55-7e40-4b09-8928-fe9155c1772d"
    }
  }
}
