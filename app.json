{
  "expo": {
    "name": "Sober Helpline",
    "slug": "SoberHelplineApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sober-helpline",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a365d"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.soberhelplineapp",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Sober Helpline records practice sessions only when you tap record, and they stay on your device."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1a365d"
      },
      "package": "com.soberhelplineapp"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1a365d",
          "resizeMode": "contain"
        }
      ],
      "expo-asset",
      "expo-localization",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1a365d",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "2858ea55-7e40-4b09-8928-fe9155c1772d"
      }
    },
    "owner": "mattbrown0406s-organization"
  }
}
